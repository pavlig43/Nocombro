# Environment for cloud/reminder-email function

# YDB
YDB_ENDPOINT=grpcs://ydb.serverless.yandexcloud.net:2135
YDB_DATABASE=/ru-central1/<folder-id>/<db-id>
YDB_IAM_TOKEN=<iam-token-or-sa-token>

# Table names
YDB_REMINDER_SOURCE_TABLE=reminder_email_source
YDB_REMINDER_RECIPIENT_TABLE=reminder_recipient
YDB_REMINDER_DELIVERY_TABLE=reminder_email_delivery

# Daily sender
REMINDER_TIMEZONE=Europe/Moscow
EMAIL_FROM=noreply@example.com
EMAIL_SUBJECT_PREFIX=[Nocombro Reminder]

# Postbox SMTP
SMTP_HOST=postbox.cloud.yandex.net
SMTP_PORT=465
SMTP_USERNAME=<postbox-username>
SMTP_PASSWORD=<postbox-password>
SMTP_USE_SSL=true
