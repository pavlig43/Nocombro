YDB_ENDPOINT=grpcs://ydb.serverless.yandexcloud.net:2135
YDB_DATABASE=/ru-central1/example/database
YDB_MIRROR_ROOT=
YDB_REMINDER_RECIPIENT_TABLE=reminder_recipient
YDB_REMINDER_DELIVERY_TABLE=reminder_email_delivery

# Cloud Functions must set:
YDB_METADATA_CREDENTIALS=1

# For local runs, remove YDB_METADATA_CREDENTIALS and set one of:
# YDB_ACCESS_TOKEN_CREDENTIALS=replace-with-local-iam-token
# YDB_SERVICE_ACCOUNT_KEY_FILE_CREDENTIALS=path-to-local-service-account-key.json

SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USERNAME=reminders@example.com
SMTP_PASSWORD=replace-me
SMTP_USE_SSL=true
EMAIL_FROM=reminders@example.com
EMAIL_SUBJECT_PREFIX="[Nocombro Reminder]"
REMINDER_TIMEZONE=Europe/Moscow
DELIVERY_SENDING_TIMEOUT_MINUTES=30
DELIVERY_MAX_ATTEMPTS=3
